# Provider API keys
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
# Optional alternative for Gemini SDK compatibility
# GOOGLE_API_KEY=your_google_api_key_here

LANGCHAIN_TRACING=
LANGCHAIN_PROJECT=
LANGCHAIN_API_KEY=

# Optional model names
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-1.5-flash

# Optional temperatures
OPENAI_TEMPERATURE=0.2
GEMINI_TEMPERATURE=0.2

# Node AssetLens API (for chat tool: GET portfolio / Zerodha / Binance routes)
ASSETLENS_API_BASE_URL=http://localhost:4000
