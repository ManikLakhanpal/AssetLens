# PostgreSQL (docker compose: postgres service + API DATABASE_URL override).
# After the first `docker compose up`, these are baked into the volume — changing them here does not alter Postgres; update to match what exists or run `docker compose down -v` (wipes DB) and start again.
# Keep POSTGRES_* in sync with DATABASE_URL in apps/api/.env (same user, password, database name).
POSTGRES_USER=trader
POSTGRES_PASSWORD=trader_dev_password
POSTGRES_DB=trader_db

# API Configuration
NODE_ENV=development
JWT_SECRET=your_jwt_secret_key_change_in_production

# LangChain/AI Configuration
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# URLs
NEXT_PUBLIC_API_URL=http://localhost:4000
